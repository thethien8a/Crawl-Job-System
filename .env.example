# Crawler autologin into ITVIEC
ITVIEC_USERNAME=
ITVIEC_PASSWORD=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
# Bucket names must be globally unique in AWS S3.
S3_BRONZE_BUCKET=
S3_SILVER_BUCKET=

# Supabase
SUPABASE_HOST=
SUPABASE_PORT=
SUPABASE_DATABASE=
SUPABASE_USER=
SUPABASE_PASSWORD=

# Supabase Metrics API for Prometheus
SUPABASE_PROJECT_REF=
SUPABASE_METRICS_SECRET_KEY=

# Monitoring layer reverse proxy (Caddy).
# Use a real DNS host in production, e.g. monitoring.lakehouse.example.com.
# Caddy auto-provisions Let's Encrypt TLS and routes:
#   /business/  ->  Bronze/Silver HTML dashboards
#   /grafana/   ->  Grafana metrics dashboards
MONITORING_DOMAIN=localhost
# Local dev uses http. Set to https in production when MONITORING_DOMAIN is real.
MONITORING_SCHEME=http

MONITORING_AUTH_USER=
# Caddy requires a hashed password. Generate one with:
# docker run --rm caddy:alpine caddy hash-password --plaintext 'your-password' > temp

# Wrap hashes containing $ in single quotes inside your real .env file.
MONITORING_AUTH_PASSWORD_HASH=

# Airflow
AIRFLOW_UID=50000
FERNET_KEY=
WEBSERVER_SECRET_KEY=

_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=

# DockerOperator
## init_orchestration.sh sets this to the absolute repo path on the deployment host.
HOST_REPO_PATH= # DON'T NEED TO SET IT, ONLY GIVE IT INTO THE .env FILE WITHOUT ANY VALUE, run init_orchestration.sh to set it

## init_orchestration.sh sets this to the host /var/run/docker.sock group id.
DOCKER_GID= # DON'T NEED TO SET IT, ONLY GIVE IT INTO THE .env FILE WITHOUT ANY VALUE, run init_orchestration.sh to set it

## Tên image pipeline
PIPELINE_IMAGE=lakehouse-crawler:latest

# MotherDuck
MOTHERDUCK_TOKEN=
# Optional: target database for the Gold layer (default: lakehouse)
MOTHERDUCK_DATABASE=

# Google Sheets source for Silver seed CSVs and clusters_review.csv (fill in your own values)
GOOGLE_SHEETS_CREDENTIALS_FILE=src/storage_layer/Sheets_Service/<your_service_file>.json
# Find your spreadsheet ID in the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=<your_spreadsheet_id>

# Prometheus scrape target for the Airflow statsd-exporter (orchestration layer).
# Single host (both layers on one machine):  statsd-exporter:9102
# Two hosts (monitoring + orchestration on separate EC2 instances):
#   <orchestration-private-ip>:9102  (open port 9102 from the monitoring
#   instance to the orchestration instance in the Security Group).
AIRFLOW_STATSD_EXPORTER_TARGET=statsd-exporter:9102
